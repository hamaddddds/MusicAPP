HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=*

# Optional: path to oauth.json / headers_auth.json (see README "Auth setup").
# Only needed for personalized library/home features. Leave blank to run
# fully unauthenticated (search, charts, artist/album/lyrics all work).
YTMUSIC_AUTH_FILE=

# Optional: path to a cookies.txt exported from a logged-in browser session.
# Helps yt-dlp with age-restricted videos and reduces bot-check throttling.
COOKIES_FILE=

# Seconds to cache a resolved audio stream URL before re-resolving.
STREAM_CACHE_TTL=3600
