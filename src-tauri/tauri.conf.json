{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Music Venue",
  "version": "0.2.23",
  "identifier": "com.music.app",
  "build": {
    "beforeDevCommand": "node scripts/download-ytdlp.mjs && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node scripts/download-ytdlp.mjs && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Music Venue",
        "width": 1024,
        "height": 720,
        "visible": false,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "externalBin": [
      "binaries/yt-dlp"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVCQUVCRjczRjcwQkQ2NzUKUldSMTFndjNjNyt1VytBaWRkenQvMnI4aTZZbm1rUkVBb2NtN01DWDZvTUFxS0hMTXRmY2Y4cUIK",
      "endpoints": [
        "https://github.com/hamaddddds/MusicAPP/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "quiet"
      }
    },
    "deep-link": {
      "schemes": [
        "musicvenue"
      ]
    }
  }
}