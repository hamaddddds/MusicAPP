{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Music Venue",
  "version": "0.2.0",
  "identifier": "com.music.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Music Venue",
        "width": 1024,
        "height": 720,
        "visible": false,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY3QjA3NjIxNTM5OEQ0RDkKUldUWjFKaFRJWGF3OTF2YkNFWXlYWVIwS0FUQkF2WHc0T3hBMzdBMU1zWlRYM1FvNEVHOVZUczkK",
      "endpoints": [
        "https://github.com/hamaddddds/MusicAPP/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
